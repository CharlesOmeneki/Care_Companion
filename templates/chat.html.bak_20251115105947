        menu.addEventListener('click', menu._internalStopper);
      }

      const blockBtn = document.getElementById('m-block-toggle');
      try {
        const blockedList = await loadBlockedCache();
        const isBlocked = blockedList.some(b => Number(b.blocked_id) === Number(activeOtherId));
        blockBtn.textContent = isBlocked ? 'Unblock user' : 'Block user';
        blockBtn.innerHTML = `<i class="fa fa-ban"></i> ${blockBtn.textContent}`;
      } catch (e) {
        blockBtn.textContent = 'Block user';
        blockBtn.innerHTML = `<i class="fa fa-ban"></i> ${blockBtn.textContent}`;
      }

      const rect = btn.getBoundingClientRect();
      menu.style.display = 'block';
      const menuWidth = menu.offsetWidth || 220;
      let left = rect.left - Math.max(40, Math.round(menuWidth/2));
      if(left < 8) left = 8;
      if(left + menuWidth > window.innerWidth - 8) left = window.innerWidth - menuWidth - 8;
      menu.style.left = left + 'px';
      menu.style.top = (rect.bottom + 8) + 'px';

      if(menu._outsideHandler){ try{ document.removeEventListener('click', menu._outsideHandler); }catch(e){} menu._outsideHandler = null; }
      if(menu._escHandler){ try{ document.removeEventListener('keydown', menu._escHandler); }catch(e){} menu._escHandler = null; }

      const outsideHandler = function(ev2){
        if(ev2.target === btn || btn.contains(ev2.target)) return;
        if(!menu.contains(ev2.target)){
          menu.style.display = 'none';
          try{ document.removeEventListener('click', outsideHandler); }catch(e){}
          try{ document.removeEventListener('keydown', escHandler); }catch(e){}
          menu._outsideHandler = null;
          menu._escHandler = null;
        }
      };

      const escHandler = function(ev3){
        if(ev3.key === 'Escape' || ev3.key === 'Esc'){
          menu.style.display = 'none';
          try{ document.removeEventListener('click', outsideHandler); }catch(e){}
          try{ document.removeEventListener('keydown', escHandler); }catch(e){}
          menu._outsideHandler = null;
          menu._escHandler = null;
        }
      };

      menu._outsideHandler = outsideHandler;
      menu._escHandler = escHandler;

      setTimeout(() => {
        document.addEventListener('click', outsideHandler);
        document.addEventListener('keydown', escHandler);
      }, 0);
    });
  }

  if(existing){
    attach(existing);
    return;
  }

  const mo = new MutationObserver((mutations, obs) => {
    const btn = document.getElementById('infoBtn');
    if(btn){
      attach(btn);
      try{ obs.disconnect(); }catch(e){}
    }
  });
  mo.observe(document.documentElement || document.body, { childList: true, subtree: true });
}

