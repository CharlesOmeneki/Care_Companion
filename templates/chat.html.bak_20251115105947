<script>

/* ---- Boot variables ---- */
const INIT_OTHER_ID = {{ other_id|tojson }};

/* ---- Socket (graceful) ---- */
const socket = (typeof io !== 'undefined') ? io() : null;

/* ---- Elements ---- */
const convList = document.getElementById('convList');
const noConvos = document.getElementById('noConvos');
const searchInput = document.getElementById('searchInput');
let messagesEl = document.getElementById('messages'); // declared once
const otherName = document.getElementById('otherName');
const otherSub = document.getElementById('otherSub');
const otherAvatar = document.getElementById('otherAvatar');
const msgInput = document.getElementById('msgInput');
const sendBtn = document.getElementById('sendBtn');
const infoBtnEl = document.getElementById('infoBtn');
const ccLogo = document.getElementById('ccLogo');
const composerReplyHolder = document.getElementById('composerReplyHolder');

let currentUser = null;
let conversationId = null;
let activeOtherId = null;
let conversations = []; // array of contact objects from /api/contacts that represent actual conversations

// guard so we only auto-open init id once
let hasAutoOpened = false;

/* toolbar / reaction state */
let replyTo = null;          // { messageId, senderName, textPreview }

/* picker globals */
let quickPicker = null;
let fullPicker = null;

/* ---- Utilities ---- */
function escapeHtml(s){ return String(s||'').replaceAll('&','&amp;').replaceAll('<','&lt;').replaceAll('>','&gt;'); }
function humanTime(ts){ if(!ts) return ''; try{ const d=new Date(ts); return isNaN(d.getTime())?ts:d.toLocaleString(); }catch(e){return ts} }

function makeAvatarUrl(u){
  const DEFAULT = '{{ url_for("static", filename="default-avatar.png") }}';
  if(!u) return DEFAULT;
  if(typeof u === 'object'){
    if(u.avatar_url) return makeAvatarUrl(u.avatar_url);
    return DEFAULT;
  }
  const s = String(u||'').trim();
  if(!s) return DEFAULT;
  if(s.startsWith('http://') || s.startsWith('https://') || s.startsWith('/')) return s;
  return '/uploads/' + s;
}

/* ---- Load me + contacts ---- */
async function loadData(){
  try{
    const meRes = await fetch('/api/me');
    if(!meRes.ok) throw new Error('unauth');
    currentUser = await meRes.json();

    const contactsRes = await fetch('/api/contacts');
    let contacts = contactsRes.ok ? await contactsRes.json() : [];

    // Keep all contacts returned by server (these should represent users you've chatted with).
    // Defensive: remove clearly empty entries and sort newest-first by last message / activity.
    conversations = Array.isArray(contacts) ? contacts.filter(Boolean) : [];

    conversations.sort((a, b) => {
      const ta = (a && a.last_message && a.last_message.created_at) || a.last_activity || a.last_seen || a.updated_at || '';
      const tb = (b && b.last_message && b.last_message.created_at) || b.last_activity || b.last_seen || b.updated_at || '';
      const da = isNaN(new Date(ta).getTime()) ? 0 : new Date(ta).getTime();
      const db = isNaN(new Date(tb).getTime()) ? 0 : new Date(tb).getTime();
      return db - da;
    });
 

    renderConversationList(conversations);

    // only auto-open on first load
    if(!hasAutoOpened){
      hasAutoOpened = true;
      if(INIT_OTHER_ID !== null && INIT_OTHER_ID !== undefined && Number(INIT_OTHER_ID) !== 0){
        openConversation(Number(INIT_OTHER_ID));
        return;
      }
    }

    highlightSelected();
  }catch(err){
    console.error('loadData', err);
  }
}
loadData();

// ----------------- socket listeners for hides/deletes -----------------
if (socket) {
  // Global delete: remove message for everyone
  socket.on('message_deleted', (payload) => {
    try {
      if (!payload) return;
      const el = document.querySelector(`.msg-row[data-msgid="${payload.message_id}"]`);
      if (el) {
        if (typeof el._cleanupControls === 'function') el._cleanupControls();
        el.remove();
      }
      cleanupOrphanControls();
    } catch (e) {
      console.error('message_deleted handler error', e);
    }
  });

  // Per-user hide: the server includes user_id so only the targeted user removes it locally
  socket.on('message_hidden', (payload) => {
    try {
      if (!payload) return;
      if (!currentUser) return; // we haven't loaded current user yet
      if (Number(payload.user_id) !== Number(currentUser.id)) return;
      const el = document.querySelector(`.msg-row[data-msgid="${payload.message_id}"]`);
      if (el) {
        if (typeof el._cleanupControls === 'function') el._cleanupControls();
        el.remove();
      }
      cleanupOrphanControls();
    } catch (e) {
      console.error('message_hidden handler error', e);
    }
  });
}

if (ccLogo) {
  ccLogo.addEventListener('click', () => {
    window.location.href = "{{ url_for('home') }}";
  });
}

function highlightSelected() {
  convList.querySelectorAll('.conv-item.selected').forEach(e => e.classList.remove('selected'));
  if (!activeOtherId) return;
  const el = convList.querySelector(`[data-id="${activeOtherId}"]`);
  if (el) {
    el.classList.add('selected');
    try { el.scrollIntoView({ block: 'nearest', inline: 'nearest' }); } catch (e) { }
  }
}

function renderConversationList(items) {
  const prevActive = activeOtherId ? Number(activeOtherId) : null;
  convList.innerHTML = '';
  if (!items.length) {
    noConvos.style.display = 'block';
    return;
  }
  noConvos.style.display = 'none';

  items.forEach(it => {
    const lastText = it.last_message ? (typeof it.last_message === 'string' ? it.last_message : (it.last_message.text || '')) : '';
    const lastAt = it.last_message && (it.last_message.created_at || '') ? humanTime(it.last_message.created_at) : '';
    const unreadCount = (it.unread && Number(it.unread) > 0) ? Number(it.unread) : 0;

    let el = document.createElement('div');
    el.className = 'conv-item' + (unreadCount ? ' unread' : '');
    el.dataset.id = it.id;
    el.innerHTML = `
      <div class="avatar"><img src="${escapeHtml(makeAvatarUrl(it.avatar_url || it))}" alt=""></div>
      <div class="meta">
        <div class="name">${escapeHtml(it.name || 'Unknown')}</div>
        <div class="snippet">${escapeHtml(lastText)}</div>
      </div>
      <div class="time">${escapeHtml(lastAt)}</div>
      ${unreadCount ? `<div class="badge" title="${unreadCount} unread">${unreadCount}</div>` : ''}
    `;
    el.addEventListener('click', () => openConversation(it.id));
    convList.appendChild(el);
  });

  if (prevActive) {
    activeOtherId = prevActive;
    highlightSelected();
  } else {
    highlightSelected();
  }
}

async function openConversation(otherId){
  activeOtherId = otherId;
  const r = await fetch(`/api/conversations/${otherId}`);
  if(!r.ok){ alert('Failed to open conversation'); return; }
  const data = await r.json();
  conversationId = data.conversation_id;
  otherName.textContent = data.other.name || 'Conversation';
  otherSub.textContent = data.other.last_seen ? 'Last seen: ' + humanTime(data.other.last_seen) : 'Online';
  otherAvatar.src = makeAvatarUrl(data.other.avatar_url || data.other);

  renderMessages(data.messages || []);

  if(socket) socket.emit('join_room',{conversation_id:conversationId});
  if(socket) socket.emit('message_read',{conversation_id:conversationId});

  const convEl = convList.querySelector(`[data-id="${otherId}"]`);
  if(convEl){
    convEl.classList.remove('unread');
    const badge = convEl.querySelector('.badge');
    if(badge) badge.remove();
    convList.querySelectorAll('.conv-item.selected').forEach(e => e.classList.remove('selected'));
    convEl.classList.add('selected');
    try{ convEl.scrollIntoView({ block: 'nearest', inline: 'nearest' }); }catch(e){}
  }

  // Refresh blocked cache & UI when opening a conversation
  blockedCache = null;
  await loadBlockedCache();
  applyBlockedUIForActive();
}

/* ---- Cleanup helpers ---- */

/* Remove any orphaned hotspot/wrap elements that don't have a matching .msg-row[data-msgid] */
function cleanupOrphanControls(){
  try{
    // Remove any hotspot or wrap where dataset.for doesn't match an existing .msg-row
    document.querySelectorAll('.msg-actions-hotspot, .msg-actions-wrap').forEach(el => {
      const fid = el.dataset && el.dataset.for ? String(el.dataset.for) : null;
      if(!fid) {
        // if there's no data-for, remove it (defensive)
        try{ el.remove(); }catch(e){}
        return;
      }
      const row = document.querySelector(`.msg-row[data-msgid="${fid}"]`);
      if(!row){
        try{ el.remove(); }catch(e){}
      }
    });
  }catch(e){ console.debug('cleanupOrphanControls failed', e); }
}

/* When removing messages (eg after delete) cleanup hotspots/wrappers */
function cleanupDeletedRows(){
  // iterate all known rows; if any are removed from DOM, call their cleanup
  try{
    const rows = Array.from(document.querySelectorAll('.msg-row'));
    rows.forEach(r => {
      // If row is not attached to the messages container (or document), run cleanup and remove
      if(!document.body.contains(r)){
        if(typeof r._cleanupControls === 'function') r._cleanupControls();
      }
    });
    // also run orphan control cleanup
    cleanupOrphanControls();
  }catch(e){ console.debug('cleanupDeletedRows', e); }
}

/* ---- Render messages ---- */
function renderMessages(messages){
  // Clean up existing rows and associated controls before re-rendering
  try{
    // call _cleanupControls for rows that will be removed
    document.querySelectorAll('.msg-row').forEach(r => {
      try{ if(typeof r._cleanupControls === 'function') r._cleanupControls(); }catch(e){}
    });
    // clear messages container
    messagesEl.innerHTML = '';
    // remove any lingering pickers/toolbars to avoid duplicates
    cleanupOrphanControls();
    document.querySelectorAll('.emoji-picker, .msg-toolbar').forEach(n => { try{ n.remove(); }catch(e){} });
  }catch(e){
    console.debug('renderMessages cleanup error', e);
  }

  if(!messages || !messages.length){
    const hint = document.createElement('div');
    hint.id = 'emptyHint';
    hint.style.textAlign = 'center';
    hint.style.color = 'var(--muted)';
    hint.style.padding = '20px';
    hint.textContent = 'No messages yet. Send the first message!';
    messagesEl.appendChild(hint);
    return;
  }
  messages.forEach(m => addMessage(m));
  messagesEl.scrollTop = messagesEl.scrollHeight;

  // Defensive cleanup after rendering
  cleanupOrphanControls();
}

/* ---- Add single message to DOM ----
   We'll create two elements per-message to support the hotspot:
   - hotspot: invisible clickable area placed directly beside the bubble
   - visible controls wrapper: shows up only when hovering hotspot/wrapper (contains three-dots + react heart)
*/
function addMessage(m){
  if(!m) return;
  const msgId = m.id;
  // Prevent duplicate rows (very defensive: check both attribute and dataset)
  if(document.querySelector(`.msg-row[data-msgid="${msgId}"]`) || document.querySelector(`[data-msgid="${msgId}"]`)) return;

  const senderId = m.sender_id || (m.sender && m.sender.id);
  const senderObj = (m.sender && typeof m.sender === 'object') ? m.sender : (Number(senderId) === Number(currentUser.id) ? currentUser : null);
  const isMe = Number(senderId) === Number(currentUser.id);

  const row = document.createElement('div');
  row.className = 'msg-row ' + (isMe ? 'me' : '');
  row.dataset.msgid = msgId;
  row.dataset.senderId = senderId;

  const avatarHtml = `<div class="avatar-sm"><img src="${escapeHtml(makeAvatarUrl(isMe ? currentUser : (senderObj || m))) }" alt=""></div>`;

  // --- replyHtml stays the same (you already have this) ---
  let replyHtml = '';
  if(m.reply_to && m.reply_to.text){
    const preview = escapeHtml(String(m.reply_to.text || '')).slice(0, 240);
    replyHtml = `<div class="reply-snippet" title="${preview}">${escapeHtml(preview)}</div>`;
  }

  // --- attachments renderer (small helper) ---
  function renderAttachmentsHTML(atts){
    try{
      if(!atts || !atts.length) return '';
      // support both array of strings (urls) or objects [{url, type, filename}]
      const parts = atts.map(a => {
        const obj = (typeof a === 'string') ? { url: a } : (a || {});
        const url = (obj.url || obj.file || obj.path || '').toString();
        if(!url) return '';
        const safeUrl = escapeHtml(String(url));
        // render image thumbnails for image types, fallback to link
        if((obj.type && String(obj.type).startsWith('image')) || /\.(jpe?g|png|gif|webp|bmp|svg)$/i.test(url)){
          return `<a class="att-link" href="${safeUrl}" target="_blank" rel="noopener noreferrer"><img class="att-img" src="${safeUrl}" alt="attachment"/></a>`;
        }
        return `<a class="att-link" href="${safeUrl}" target="_blank" rel="noopener noreferrer">${safeUrl}</a>`;
      }).filter(Boolean);
      if(!parts.length) return '';
      return `<div class="message-attachments">${parts.join('')}</div>`;
    }catch(e){
      console.error('renderAttachmentsHTML', e);
      return '';
    }
  }

  // Debug: helpful when images don't appear
  console.debug('addMessage payload', m);

  // build attachments HTML (if any)
  const attachmentsHtml = renderAttachmentsHTML(m.attachments || []);

  // Build the bubble HTML (text + attachments + meta + reactions)
  const bubbleHtml = `
    <div class="bubble ${isMe ? 'me' : ''}">
      ${replyHtml}
      <div>${escapeHtml(m.text || '')}</div>
      ${attachmentsHtml}
      <div class="meta-time">${humanTime(m.created_at)} ${m.status ? ' · ' + escapeHtml(m.status) : ''}</div>
      ${renderReactionsInline(m.reactions || [])}
    </div>
  `;

  // finally attach to the row
  row.innerHTML = avatarHtml + bubbleHtml;

  // create hotspot + visible controls wrapper and position them beside the bubble
  const hotspot = document.createElement('div');
  hotspot.className = 'msg-actions-hotspot';
  hotspot.setAttribute('aria-hidden','false');
  hotspot.dataset.for = String(msgId);

  const wrap = document.createElement('div');
  wrap.className = 'msg-actions-wrap';
  wrap.setAttribute('aria-hidden','true');
  wrap.dataset.for = String(msgId);

  // create three-dot button
  const dotBtn = document.createElement('button');
  dotBtn.className = 'msg-actions-button';
  dotBtn.setAttribute('title','Message actions');
  dotBtn.innerHTML = '<i class="fa fa-ellipsis-vertical" aria-hidden="true"></i>';

  // create react (love) button (muted color like dots)
  const reactBtn = document.createElement('button');
  reactBtn.className = 'react-button';
  reactBtn.setAttribute('title', 'React');
  reactBtn.innerHTML = '<i class="fa fa-heart" aria-hidden="true"></i>';

  // append buttons to wrapper
  wrap.appendChild(dotBtn);
  wrap.appendChild(reactBtn);

  // append wrapper and hotspot to document body (absolute positioning)
  // Defensive: remove any existing elements for this msgId first to avoid duplicates
  try{
    document.querySelectorAll(`.msg-actions-hotspot[data-for="${msgId}"], .msg-actions-wrap[data-for="${msgId}"]`).forEach(n => { try{ n.remove(); }catch(e){} });
  }catch(e){}
  document.body.appendChild(hotspot);
  document.body.appendChild(wrap);

  // emoji-picker references (per message)
  let localQuick = null;
  let localFull = null;

  // helper to compute placement: based on bubble rect (so it's right beside the bubble)
  function positionControls(){
    try{
      const rowRect = row.getBoundingClientRect();
      const bubbleEl = row.querySelector('.bubble');
      if(!bubbleEl) return;
      const bubbleRect = bubbleEl.getBoundingClientRect();
      const wrapW = wrap.offsetWidth || 76; // two buttons + gap (~76)
      const hsW = hotspot.offsetWidth || 70;
      let left;
      // place to the right of incoming bubble, to the left of own bubble
      if(isMe){
        // left of the bubble (small gap)
        left = Math.round(bubbleRect.left - wrapW - 8);
      } else {
        // right of the bubble
        left = Math.round(bubbleRect.right + 8);
      }
      // ensure within viewport
      if(left < 6) left = 6;
      if(left + wrapW > window.innerWidth - 6) left = window.innerWidth - wrapW - 6;

      const top = Math.round(bubbleRect.top + (bubbleRect.height/2) - (wrap.offsetHeight/2));

      wrap.style.left = (left + window.scrollX) + 'px';
      wrap.style.top = (top + window.scrollY) + 'px';

      // hotspot positioned to cover the wrapper area (centered)
      const hsLeft = Math.round(left + (wrapW/2) - (hsW/2));
      const hsTop = Math.round(bubbleRect.top + (bubbleRect.height/2) - (hotspot.offsetHeight/2));
      hotspot.style.left = (hsLeft + window.scrollX) + 'px';
      hotspot.style.top = (hsTop + window.scrollY) + 'px';

      // position any open pickers close to anchor
      if(localQuick) positionPickerNearAnchor(localQuick, reactBtn);
      if(localFull) positionPickerNearAnchor(localFull, reactBtn);
    }catch(e){ console.debug('positionControls error', e); }
  }

  // show/hide logic: show when hotspot hovered OR wrapper hovered; hide otherwise
  function showWrap(){
    wrap.classList.add('visible');
    wrap.setAttribute('aria-hidden','false');
  }
  function hideWrap(){
    // delay to allow entering picker; don't remove immediately if pickers hovered
    setTimeout(()=> {
      const pickHovered = (localQuick && localQuick.matches(':hover')) || (localFull && localFull.matches(':hover'));
      if(pickHovered) return; // keep open
      wrap.classList.remove('visible');
      wrap.setAttribute('aria-hidden','true');
      removeLocalQuick();
      removeLocalFull();
    }, 80);
  }

  // Attach event listeners to hotspot and wrapper so it behaves like hover hotspot
  hotspot.addEventListener('mouseenter', (e) => { showWrap(); });
  hotspot.addEventListener('mouseleave', (e) => { setTimeout(()=> { if(!wrap.matches(':hover')) hideWrap(); }, 80); });
  wrap.addEventListener('mouseenter', ()=> { showWrap(); });
  wrap.addEventListener('mouseleave', ()=> { setTimeout(()=> { if(!hotspot.matches(':hover')) hideWrap(); }, 80); });

  // clicking the dot opens the message toolbar
  dotBtn.addEventListener('click', (ev) => {
    ev.stopPropagation();
    showMessageToolbar(row, m, dotBtn);
  });

  // clicking the react heart opens an emoji quick-picker (five) or toggles it closed
  reactBtn.addEventListener('click', (ev) => {
    ev.stopPropagation();
    if(localQuick || localFull){
      // toggle off
      removeLocalQuick();
      removeLocalFull();
      hideWrap();
      return;
    }
    showLocalQuick(reactBtn, row, m);
  });

  /* ------------ picker helpers (per message) ------------- */

  // list for the small quick row (5) and the big full grid (many)
  const QUICK_EMOJIS = ['❤','👍','😂','😮','😢'];
  const ALL_EMOJIS = [
    '❤','🧡','💛','💚','💙','💜','🤎','🖤','🤍',
    '👍','👎','👌','👏','🙌','🤝',
    '😂','🤣','😊','😅','😁','🙂','🤗','☺️',
    '😮','😲','😳','🤯',
    '😢','😭','😞','😔','😕','😤','😠','😡',
    '😇','🥰','😍','😘','😋','🤤','😎','🤩',
    '🤔','🤨','😐','😑','😶',
    '🙃','🤪','😴','🥱','🤤','🤠','🥳','🤡',
    '🔥','💯','⭐','✨','🎉','🙏','🫶','🤍'
  ];

  function positionPickerNearAnchor(pickerEl, anchorEl){
    try{
      const rect = anchorEl.getBoundingClientRect();
      const pw = pickerEl.offsetWidth || Math.min(320, window.innerWidth - 32);
      let left = rect.left + window.scrollX - Math.round((pw - rect.width) / 2);
      let top = rect.top + window.scrollY - pickerEl.offsetHeight - 8;
      if(left < 8) left = 8;
      if(left + pw > window.innerWidth - 8) left = window.innerWidth - pw - 8;
      if(top < 8) top = rect.bottom + window.scrollY + 8;
      pickerEl.style.left = left + 'px';
      pickerEl.style.top = top + 'px';
    }catch(e){ console.debug('positionPicker error', e); }
  }

  function removeLocalQuick(){
    if(localQuick){
      try{ localQuick.remove(); }catch(e){}
      localQuick = null;
    }
  }
  function removeLocalFull(){
    if(localFull){
      try{ localFull.remove(); }catch(e){}
      localFull = null;
    }
  }

  function showLocalQuick(anchorEl, rowEl, messageObj){
    removeLocalQuick();
    removeLocalFull();

    localQuick = document.createElement('div');
    localQuick.className = 'emoji-picker';
    localQuick.style.display = 'flex';
    localQuick.style.flexWrap = 'nowrap';
    localQuick.style.alignItems = 'center';
    localQuick.style.padding = '6px';

    // quick 5
    QUICK_EMOJIS.forEach(e => {
