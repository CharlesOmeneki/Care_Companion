// --- Replace your existing sendMessage() function with this updated version ---
function sendMessage(){
  if(!conversationId){ alert('Open a conversation first'); return; }
  let text = msgInput.value.trim();
  if(!text) return;

  // If replying, include reply_to id in payload; we still keep prefixed @ as optional UX
  const reply_to_id = replyTo ? replyTo.messageId : null;

  if(replyTo && replyTo.senderName){
    // Maintain a lightweight mention to help UX but do not rely on it server-side
    if(!text.startsWith(`@${replyTo.senderName}`)){
      text = `@${replyTo.senderName} ${text}`;
    }
  }

  const tempId = 'temp_' + Date.now();
  const tempMsg = {
    id: tempId,
    conversation_id: conversationId,
    sender_id: currentUser.id,
    text: text,
    created_at: new Date().toISOString(),
    status: 'sending',
    sender: currentUser,
    reply_to: reply_to_id ? { id: reply_to_id, text: replyTo ? (replyTo.textPreview || '') : '' } : null,
    reactions: []
  };
  addMessage(tempMsg);
  msgInput.value = '';
  // keep replyTo until server ack or user cancels
  // but clear composer preview
  replyTo = replyTo; // unchanged
  renderComposerReply();

  // Helper to produce a readable reason from server ack/json
  function reasonFromServerPayload(p) {
    if(!p) return 'Failed to send message';
    if(p.error === 'blocked') return (p.message || 'This user has blocked you');
    if(p.message && typeof p.message === 'string') return p.message;
    if(p.error && typeof p.error === 'string') return p.error;
    return 'Failed to send message';
  }

  if(socket){
    socket.emit('send_message',{conversation_id:conversationId, text, attachments:[], reply_to: reply_to_id}, (ack) => {
      try {
        if(ack && ack.success && ack.message){
          const serverMsg = ack.message;
          const serverEl = document.querySelector(`.msg-row[data-msgid="${serverMsg.id}"]`);
          const tempEl = document.querySelector(`.msg-row[data-msgid="${tempId}"]`);
          if(serverEl && tempEl){
            // remove temp
            if(typeof tempEl._cleanupControls === 'function') tempEl._cleanupControls();
            tempEl.remove();
          } else if(!serverEl && tempEl){
            // update temp element to server id and update contents
            tempEl.dataset.msgid = serverMsg.id;
            // ensure hotspot/wrap dataset.for updated to new id (if they exist)
            document.querySelectorAll(`.msg-actions-hotspot[data-for="${tempId}"], .msg-actions-wrap[data-for="${tempId}"]`).forEach(el => { el.dataset.for = String(serverMsg.id); });
            const bubble = tempEl.querySelector('.bubble');
            if(bubble){
              const txtNode = bubble.querySelector('div:not(.reply-snippet)');
              if(txtNode) txtNode.innerHTML = escapeHtml(serverMsg.text || '');
              const meta = bubble.querySelector('.meta-time');
              if(meta) meta.textContent = humanTime(serverMsg.created_at) + ' · ' + (serverMsg.status || 'Delivered');
              // update reply snippet if server provided one
              if(serverMsg.reply_to && serverMsg.reply_to.text){
                let rs = bubble.querySelector('.reply-snippet');
                if(!rs){
                  // insert at top of bubble
                  bubble.insertAdjacentHTML('afterbegin', `<div class="reply-snippet">${escapeHtml(serverMsg.reply_to.text.slice(0,240))}</div>`);
                } else {
                  rs.textContent = serverMsg.reply_to.text.slice(0,240);
                }
              }
              // update reactions
              if(serverMsg.reactions) updateMessageReactions(serverMsg.id, serverMsg.reactions || []);
            }
          } else if(!serverEl && !tempEl){
            // nothing matched, just append server message
            addMessage(serverMsg);
          }
          // after successful send, clear replyTo & composer preview
          replyTo = null;
          renderComposerReply();
          loadData();
          return;
        }

        // Not successful: mark temp failed and show specific message if the server provided one
        const reason = reasonFromServerPayload(ack);
        markTempFailed(tempId, reason);
        alert(reason);
      } catch(e){
        console.error('socket send_message ack handling error', e);
        // defensive fallback: mark as failed
        markTempFailed(tempId, 'Failed to send message');
        alert('Failed to send message');
      }
    });
  } else {
    fetch('/api/send_message',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({conversation_id:conversationId,text,reply_to:reply_to_id})})
      .then(r => r.json().catch(()=>({})))
      .then(j => {
        try {
          if(j && j.success && j.message){
            // remove temp if present and append server message
            const tempEl = document.querySelector(`.msg-row[data-msgid="${tempId}"]`);
            if(tempEl){
              if(typeof tempEl._cleanupControls === 'function') tempEl._cleanupControls();
              tempEl.remove();
            }
            addMessage(j.message);
            loadData();
            replyTo = null;
            renderComposerReply();
            return;
          }
          // failure: display better reason when blocked
          const reason = reasonFromServerPayload(j);
          markTempFailed(tempId, reason);
          alert(reason);
        } catch(e){
          console.error('sendMessage fallback handler error', e);
          markTempFailed(tempId, 'Failed to send message');
          alert('Failed to send message');
        }
      }).catch(err=>{
        console.error('sendMessage fallback failed', err);
        markTempFailed(tempId, 'Failed to send message');
        alert('Failed to send message');
      });
  }
}


/* ---- Moderation helpers ---- */
async function deleteMessage(msgId){
  // confirm
  if(!confirm('Delete this message? This cannot be undone.')) return;

  try{
    // find the row to know who sent it
    const row = document.querySelector(`.msg-row[data-msgid="${msgId}"]`);
    const senderId = row && row.dataset && row.dataset.senderId ? String(row.dataset.senderId) : null;
    const isMe = (senderId && currentUser && String(currentUser.id) && String(senderId) === String(currentUser.id));

    // If the current user is NOT the sender, prefer a local-only hide (so only their view is affected)
    const local_only = !isMe;

    const payload = local_only ? { local_only: true } : {};

    const res = await fetch('/api/messages/' + encodeURIComponent(msgId), {
      method: 'DELETE',
      headers: { 'Content-Type': 'application/json' },
      body: Object.keys(payload).length ? JSON.stringify(payload) : null
    });

    let j = null;
    try { j = await res.json(); } catch(e){ /* not JSON */ }

    if(res.ok && j && j.success){
      // If server responded OK (either hidden or deleted), remove local row
      const el = document.querySelector(`.msg-row[data-msgid="${msgId}"]`);
      if(el){
        if(typeof el._cleanupControls === 'function') el._cleanupControls();
        el.remove();
      }
      cleanupOrphanControls();
      return;
    }

    // Not OK - show helpful message
    const errText = (j && (j.error || j.message)) ? (j.error || j.message) : (j ? JSON.stringify(j) : ('HTTP ' + res.status));
    // If it's a forbidden action (403) and we tried global delete, suggest local hide
    if(res.status === 403 && !local_only){
      alert('You are not allowed to delete this message for everyone. Will attempt to hide locally instead.');
      // try local-only hide as fallback
      await fetch('/api/messages/' + encodeURIComponent(msgId) + '?', {
        method: 'DELETE',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ local_only: true })
      }).then(async (r2) => {
        try {
          const j2 = await r2.json();
          if(r2.ok && j2 && j2.success) {
            const el2 = document.querySelector(`.msg-row[data-msgid="${msgId}"]`);
            if(el2){ if(typeof el2._cleanupControls === 'function') el2._cleanupControls(); el2.remove(); }
            cleanupOrphanControls();
            return;
          } else {
            alert('Hide locally failed: ' + (j2 && (j2.error || j2.message) || r2.status));
          }
        } catch(e){
          alert('Hide locally: unexpected server response');
        }
      }).catch(e => {
        console.error(e);
        alert('Hide locally failed - see console.');
      });
      return;
    }

    // generic failure
    alert('Delete failed: ' + errText);
    console.warn('deleteMessage failed', res.status, j);
  }catch(e){
    console.error(e);
    alert('Delete request failed (see console)');
  }
}


async function editMessage(msgId){
  const el = document.querySelector(`.msg-row[data-msgid="${msgId}"]`);
  if(!el) { alert('Message not found'); return; }
  const bubble = el.querySelector('.bubble > div:not(.reply-snippet)');
  const old = bubble ? bubble.textContent.trim() : '';
  const newText = prompt('Edit message:', old);
  if(newText === null) return; // cancelled
  if(String(newText).trim() === String(old).trim()) return;
  try{
    const res = await fetch(`/api/messages/${msgId}/edit`, {
      method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify({ text: newText })
    });
    const j = await res.json();
    if(res.ok && j.success && j.message){
      if(bubble) bubble.textContent = j.message.text;
      const meta = el.querySelector('.meta-time');
      if(meta) meta.textContent = new Date(j.message.created_at).toLocaleString() + ' · ' + (j.message.status || 'edited');
    } else {
      alert('Edit failed: ' + (j.error || 'unknown'));
    }
  }catch(e){
    console.error(e);
    alert('Edit failed');
  }
}

/* ---- Floating toolbar (anchored to button if provided) ---- */
/* DROP-IN replacement: robust, safe, and ensures observer cleanup. */
function showMessageToolbar(rowEl, messageObj, anchorEl = null){
  try {
    // close any existing toolbars first
    removeMessageToolbar();

    // basic defensive checks
    if(!rowEl && (!messageObj || !messageObj.id)){
      console.warn('showMessageToolbar called without a row element or message id', { rowEl, messageObj });
      return;
    }

    const toolbar = document.createElement('div');
    toolbar.className = 'msg-toolbar';

    // Prefer live dataset if available, fallback to messageObj.id
    const initialMid = (rowEl && rowEl.dataset && rowEl.dataset.msgid) ? rowEl.dataset.msgid : (messageObj && messageObj.id ? messageObj.id : null);
    toolbar.dataset.for = initialMid || '';

    // helper to read freshest ids/text at click time
    function currentIds(){
      const mid = (toolbar.dataset && toolbar.dataset.for) ? toolbar.dataset.for : (rowEl && rowEl.dataset && rowEl.dataset.msgid) ? rowEl.dataset.msgid : (messageObj && messageObj.id ? messageObj.id : null);
      const senderId = (rowEl && rowEl.dataset && rowEl.dataset.senderId) ? rowEl.dataset.senderId : (messageObj && messageObj.sender_id ? messageObj.sender_id : null);
      const bubbleTextEl = rowEl ? rowEl.querySelector('.bubble > div:not(.reply-snippet)') : null;
      const bubbleText = bubbleTextEl ? (bubbleTextEl.textContent || '').trim() : (messageObj && messageObj.text ? String(messageObj.text) : '');
      return { mid, senderId, bubbleText };
    }

    // Buttons and their handlers (use freshest id from currentIds())
    const replyBtn = document.createElement('button');
    replyBtn.title = 'Reply';
    replyBtn.innerHTML = '<i class="fa fa-reply"></i> Reply';
    replyBtn.addEventListener('click', () => {
      try {
        const { mid, bubbleText } = currentIds();
        if(!mid){ alert('Unable to locate message to reply to.'); return; }
        const pseudoMsg = { id: mid, text: bubbleText, sender: messageObj && messageObj.sender ? messageObj.sender : {} };
        replyToMessage(mid, pseudoMsg);
      } catch (e){ console.error('reply error', e); }
      removeMessageToolbar();
    });

    const forwardBtn = document.createElement('button');
    forwardBtn.title = 'Forward';
    forwardBtn.innerHTML = '<i class="fa fa-share"></i> Forward';
    forwardBtn.addEventListener('click', () => {
      try {
        const { mid } = currentIds();
        if(!mid){ alert('Unable to locate message to forward.'); return; }
        showForwardModal(mid);
      } catch (e){ console.error('forward error', e); }
      removeMessageToolbar();
    });

    const copyBtn = document.createElement('button');
    copyBtn.title = 'Copy';
    copyBtn.innerHTML = '<i class="fa fa-copy"></i> Copy';
    copyBtn.addEventListener('click', () => {
      try {
        const { mid } = currentIds();
        if(!mid){ alert('Unable to locate message to copy.'); return; }
        copyMessageToClipboard(mid);
      } catch (e){ console.error('copy error', e); }
      removeMessageToolbar();
    });

    const editBtn = document.createElement('button');
    editBtn.title = 'Edit';
    editBtn.innerHTML = '<i class="fa fa-pen"></i> Edit';
    editBtn.addEventListener('click', async () => {
      try {
        const { mid } = currentIds();
        if(!mid){ alert('Unable to locate message to edit.'); return; }
        await editMessage(mid);
      } catch (e){ console.error('edit error', e); }
      removeMessageToolbar();
    });

    const delBtn = document.createElement('button');
    delBtn.title = 'Delete';
    delBtn.innerHTML = '<i class="fa fa-trash"></i> Delete';
    delBtn.className = 'danger';
    delBtn.addEventListener('click', async () => {
      try {
        const { mid } = currentIds();
        if(!mid){ alert('Could not determine message id to delete.'); removeMessageToolbar(); return; }
        await deleteMessage(mid);
      } catch (e) {
        console.error('delete error', e);
      } finally {
        removeMessageToolbar();
      }
    });

    // Append in same order as before
    toolbar.appendChild(replyBtn);
    toolbar.appendChild(forwardBtn);
    toolbar.appendChild(copyBtn);

    // decide append order using the freshest sender id
    const { senderId } = currentIds();
    const isMine = (senderId !== null && currentUser && typeof currentUser.id !== 'undefined' && Number(senderId) === Number(currentUser.id));
    if(isMine){
      toolbar.appendChild(editBtn);
      toolbar.appendChild(delBtn);
    } else {
      toolbar.appendChild(delBtn);
    }

    // Add to DOM BEFORE measuring/positioning so offsetWidth/Height are available
    document.body.appendChild(toolbar);

    // position near anchor or message row and keep inside viewport (defensive)
    let anchorRect = null;
    try { anchorRect = anchorEl ? anchorEl.getBoundingClientRect() : null; } catch(e){ anchorRect = null; }
    let rowRect = { left: 0, right: 0, top: 0, height: 40 };
    try { if(rowEl) rowRect = rowEl.getBoundingClientRect(); } catch(e){ /* keep fallback */ }

    const tw = toolbar.offsetWidth || 160;
    const th = toolbar.offsetHeight || ((toolbar.children.length || 1) * 40);
    let left, top;

    if(anchorRect){
      left = anchorRect.left + window.scrollX - Math.round((tw - anchorRect.width) / 2);
      top = anchorRect.top + window.scrollY - th - 8;
    } else {
      const rightSide = rowRect.right + window.scrollX + 8;
      const leftSide = rowRect.left + window.scrollX - tw - 8;
      if(rightSide + tw <= window.innerWidth - 8){
        left = rightSide;
      } else {
        left = Math.max(8, leftSide);
      }
      top = rowRect.top + window.scrollY + Math.round((rowRect.height / 2) - (th / 2));
    }

    // ensure bounds
    if(left < 8) left = 8;
    if(left + tw > window.innerWidth - 8) left = window.innerWidth - tw - 8;
    if(top < 8) top = 8;
    if(top + th > window.innerHeight - 8) top = window.innerHeight - th - 8;

    toolbar.style.left = left + 'px';
    toolbar.style.top = top + 'px';

    // If row's data-msgid may change (temp -> server id), observe it and keep toolbar.dataset.for current
    let observer = null;
    if(window.MutationObserver && rowEl){
      try {
        observer = new MutationObserver(() => {
          try {
            const latest = rowEl.dataset && rowEl.dataset.msgid ? rowEl.dataset.msgid : null;
            if(latest) toolbar.dataset.for = latest;
          } catch(e){ /* ignore */ }
        });
        observer.observe(rowEl, { attributes: true, attributeFilter: ['data-msgid'] });
      } catch(e){ console.debug('observer init failed', e); }
    }
    // attach the observer reference so removal can disconnect it
    toolbar._observer = observer;
    toolbar._row = rowEl;

    // close toolbar when clicking outside (single-use listener)
    setTimeout(()=> {
      document.addEventListener('click', function onceClose(e){
        if(!toolbar.contains(e.target) && !(anchorEl && anchorEl.contains(e.target))) {
          removeMessageToolbar();
        }
      }, { once: true });
    }, 0);

  } catch (err) {
    console.error('showMessageToolbar fatal error', err);
