/* Handle external app forward */
function handleForwardExternal(appId){
  const text = _forwardingMessageText || '';
  if(!text) { alert('No message to forward'); return; }
  const encoded = encodeURIComponent(text);
  if(appId === 'email'){
    const subject = encodeURIComponent('Forwarded message');
    const href = `mailto:?subject=${subject}&body=${encoded}`;
    window.open(href, '_blank');
  } else if(appId === 'whatsapp'){
    // Using wa.me with text
    const href = `https://wa.me/?text=${encoded}`;
    window.open(href, '_blank');
  } else if(appId === 'x'){
    const href = `https://twitter.com/intent/tweet?text=${encoded}`;
    window.open(href, '_blank');
  } else if(appId === 'telegram'){
    const href = `https://t.me/share/url?url=&text=${encoded}`;
    window.open(href, '_blank');
  } else if(appId === 'copy'){
    if(navigator.clipboard && navigator.clipboard.writeText){
      navigator.clipboard.writeText(text).then(()=> {
        alert('Message text copied to clipboard');
      }).catch(()=> alert('Copy failed'));
    } else {
      const ta = document.createElement('textarea');
      ta.value = text;
      document.body.appendChild(ta);
      ta.select();
      try{ document.execCommand('copy'); alert('Message copied'); }catch(e){ alert('Copy failed'); }
      ta.remove();
    }
  } else {
    alert('Not supported');
  }
}

/* Forward in-app to conversation ID (or user ID) */
async function forwardInAppToConversation(targetId, text, originalMsgId = null){
  if(!targetId || !text) return;
  // assume targetId is user id from /api/contacts
  const toId = Number(targetId);
  if(!toId){ alert('Invalid target'); return; }

  // Build conversation_id format used in your app: conv_<min>_<max>
  const a = Math.min(Number(currentUser.id), toId);
  const b = Math.max(Number(currentUser.id), toId);
  const conv = `conv_${a}_${b}`;
  const forwardText = `FW: ${text}`;

  // Try socket first, otherwise fallback to API
  if(socket){
    socket.emit('send_message', { conversation_id: conv, text: forwardText, attachments: [], forward_from: originalMsgId || null }, (ack) => {
      if(ack && ack.success){
        alert('Forwarded in-app');
        loadData();
      } else {
        // fallback to fetch if ack fails
        fetch('/api/send_message',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({conversation_id:conv,text:forwardText,forward_from: originalMsgId || null})})
          .then(r=>r.json()).then(j => {
            if(j && j.success) alert('Forwarded in-app');
            else alert('Forward failed');
            loadData();
          }).catch(e => { console.error(e); alert('Forward failed'); });
      }
    });
  } else {
    fetch('/api/send_message',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({conversation_id:conv,text:forwardText,forward_from: originalMsgId || null})})
      .then(r=>r.json()).then(j => {
        if(j && j.success) alert('Forwarded in-app');
        else alert('Forward failed');
        loadData();
      }).catch(e => { console.error(e); alert('Forward failed'); });
  }
}

