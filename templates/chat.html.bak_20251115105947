<script>
/* ---------- Robust boxed image viewer (single guarded implementation) ---------- */

/* global flag so other handlers can detect when the viewer is open */
window.__imageViewerVisible = window.__imageViewerVisible || false;

/* Create overlay DOM if not present */
(function ensureImageViewerDom(){
  if (document.getElementById('imageViewerOverlay')) return;

  const ov = document.createElement('div');
  ov.id = 'imageViewerOverlay';
  ov.className = 'image-viewer-overlay';
  ov.style.display = 'none';
  ov.innerHTML = `
    <div class="image-viewer-inner" role="dialog" aria-modal="true" aria-label="Image preview">
      <div class="image-viewer-frame">
        <img id="imageViewerImg" class="viewer-img" src="" alt="Image preview"/>
        <button id="imageViewerClose" class="image-viewer-close" title="Close">Close</button>
        <div id="imageViewerCaption" class="image-viewer-caption"></div>
      </div>
    </div>
  `;
  document.body.appendChild(ov);

  // Stop clicks inside overlay from bubbling to other page handlers.
  // If user clicks the overlay background (not the inner frame), close.
  ov.addEventListener('click', function(ev){
    // If clicked the background overlay area (the element itself), close viewer.
    if(ev.target === ov){
      ev.stopPropagation();
      ev.preventDefault();
      closeImageViewer();
    }
    // otherwise allow inner elements (image / close button) to handle themselves.
  }, true); // use capture to be defensive
})();

/* Open viewer: set guard and prepare handlers */
function openImageViewer(url, caption){
  try {
    const ov = document.getElementById('imageViewerOverlay');
    const img = document.getElementById('imageViewerImg');
    const cap = document.getElementById('imageViewerCaption');
    const closeBtn = document.getElementById('imageViewerClose');
    if(!ov || !img) { window.open(url, '_blank'); return; }

    // Mark viewer visible immediately (prevents other handlers from acting)
    window.__imageViewerVisible = true;

    // Show overlay and prevent page scroll
    ov.classList.add('visible');
    ov.style.display = 'flex';
    document.body.style.overflow = 'hidden';

    // Caption
    if(cap) cap.textContent = caption || '';

    // Reset handlers to avoid duplicates
    img.onload = null;
    img.onerror = null;
    img.onclick = null;
    if(closeBtn){
      try { closeBtn.removeEventListener('click', closeImageViewerCaptureGuard, true); } catch(e){}
      // attach a capture-phase handler so it stops propagation early
      closeBtn.addEventListener('click', closeImageViewerCaptureGuard, true);
    }

    // Prevent clicks on the image from bubbling back to delegated handlers that could re-open images.
    img.addEventListener('click', function(ev){
      ev.stopPropagation();
      ev.preventDefault();
    }, true);

    // onload: CSS does the fitting; ensure object-fit for older browsers
    img.onload = function(){
      try {
        img.style.objectFit = 'contain';
        img.style.objectPosition = 'center center';
        img.style.maxWidth = '100%';
        img.style.maxHeight = '100%';
      } catch(e){}
    };

    // onerror fallback: close viewer and open image in new tab
    img.onerror = function(){
      try { closeImageViewer(); } catch(e){}
      try { window.open(url, '_blank'); } catch(e){}
    };

    // set src last to start loading
    img.src = url;
  } catch(e){
    console.error('openImageViewer error', e);
    try { window.open(url, '_blank'); } catch(ignore){}
  }
}

/* capture-phase close handler that stops propagation immediately */
function closeImageViewerCaptureGuard(ev){
  try {
    ev.stopPropagation();
    ev.preventDefault();
  } catch(e){}
  // call close function (non-event variant)
  closeImageViewer();
}

/* Close viewer: clear guard and restore page state */
function closeImageViewer(){
  try {
    const ov = document.getElementById('imageViewerOverlay');
    const img = document.getElementById('imageViewerImg');
    const cap = document.getElementById('imageViewerCaption');
    const closeBtn = document.getElementById('imageViewerClose');
    if(!ov) return;

    // Hide overlay and restore scroll immediately
    ov.classList.remove('visible');
    ov.style.display = 'none';
    document.body.style.overflow = '';

    // remove close button capture handler (defensive)
    if(closeBtn){
      try { closeBtn.removeEventListener('click', closeImageViewerCaptureGuard, true); } catch(e){}
    }

    // Clear image + caption after brief delay (avoids flicker)
    setTimeout(()=> {
      try {
        if(img){
          // remove image click guard and src
          try { img.removeEventListener('click', function(){}); } catch(e){}
          img.onclick = null;
          img.src = '';
        }
      } catch(e){}
      try { if(cap) cap.textContent = ''; } catch(e){}
    }, 150);

    // mark viewer not visible so other handlers resume
    window.__imageViewerVisible = false;
  } catch(e){
    console.error('closeImageViewer error', e);
  }
}

/* ---------- Document capture-phase blocker (robust replacement) ----------
   Prevents legacy document/bubble handlers from reopening the full-size
   image while the boxed viewer is visible. Carefully allows the overlay's
   close actions (close button / backdrop) to work by invoking them directly
   and still blocking other legacy handlers.
*/
(function installDocumentCaptureBlocker(){
  if(window.__imageViewerDocBlockInstalled) return;
  window.__imageViewerDocBlockInstalled = true;

  document.addEventListener('click', function(ev){
    try {
      // If viewer not visible, nothing to do here.
      if(!window.__imageViewerVisible) return;

      // Respect user intent to open in new tab/window
      if(ev.ctrlKey || ev.metaKey || ev.shiftKey) return;

      // Defensive: get overlay and inner pieces
      const ov = document.getElementById('imageViewerOverlay');
      const closeBtn = document.getElementById('imageViewerClose');

      // If click is outside the overlay, block any att-link or uploads navigation
      // and prevent legacy handlers from firing.
      const outsideLink = ev.target && ev.target.closest ? ev.target.closest('.att-link, a[href]') : null;
      if(outsideLink) {
        // If it's an att-link OR an /uploads/ anchor, block it entirely.
        const href = outsideLink.getAttribute && outsideLink.getAttribute('href') || '';
        const isAtt = outsideLink.classList && outsideLink.classList.contains && outsideLink.classList.contains('att-link');
        const isUploadHref = typeof href === 'string' && /\/uploads\//.test(href);
        if(isAtt || isUploadHref) {
          // Prevent legacy handlers and navigation.
          ev.stopImmediatePropagation();
          ev.preventDefault();
          return;
        }
      }

      // If click occurred inside the overlay we need to prevent legacy handlers
      // but still allow the overlay's close interactions to work.
      if(ov && ov.contains(ev.target)) {
        // If user clicked on the backdrop (overlay container itself), treat as close.
        if(ev.target === ov) {
          // Stop other handlers and run overlay close ourselves.
          ev.stopImmediatePropagation();
          ev.preventDefault();
          try { closeImageViewer(); } catch(err){ /* swallow */ }
          return;
        }

        // If click was on the close button (or inside it), close and stop propagation.
        if(closeBtn && (ev.target === closeBtn || closeBtn.contains(ev.target))) {
          ev.stopImmediatePropagation();
          ev.preventDefault();
          try { closeImageViewer(); } catch(err){ /* swallow */ }
          return;
        }

        // Otherwise the click is somewhere inside the inner frame (image, caption, etc).
        // Block legacy handlers from receiving this event (they're the ones reopening the image),
        // but do not trigger any overlay action here — let overlay remain visible.
        ev.stopImmediatePropagation();
        ev.preventDefault();
        return;
      }

      // Otherwise: viewer is visible, and click was not inside overlay.
      // Block generic navigations to /uploads just in case some legacy handler would open them.
      const a = ev.target && ev.target.closest ? ev.target.closest('a[href]') : null;
      if(a) {
        const href = a.getAttribute('href') || '';
        if(/\/uploads\//.test(href)) {
          ev.stopImmediatePropagation();
          ev.preventDefault();
          return;
        }
      }

      // For all other cases when viewer visible: be defensive and prevent propagation.
      // (This avoids odd race conditions where other handlers may re-open.)
      ev.stopImmediatePropagation();
      ev.preventDefault();
      return;

    } catch(err){
      // Keep page working even if blocker has an error
      console.debug('document capture blocker error', err);
      try { ev.stopImmediatePropagation(); ev.preventDefault(); } catch(e){/*ignore*/ }
      return;
    }
  }, true); // capture-phase
})();

/* ---------- Delegated click handler on #messages to open boxed viewer ----------
   Only this handler performs the "open" action. This keeps a single source of truth.

// add this as the very first lines inside the existing handler
