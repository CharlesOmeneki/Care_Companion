    localFull.addEventListener('mouseenter', ()=> { showWrap(); });
    localFull.addEventListener('mouseleave', ()=> { setTimeout(()=> { if(!wrap.matches(':hover')) { removeLocalFull(); hideWrap(); } }, 80); });
  }

  // helper to send reaction toggle to server
  async function sendReaction(msgIdLocal, emoji){
    try{
      const res = await fetch(`/api/messages/${encodeURIComponent(msgIdLocal)}/react`, {
        method: 'POST',
        headers: {'Content-Type':'application/json'},
        body: JSON.stringify({ emoji })
      });
      const j = await res.json();
      if(res.ok && j.success){
        // update inline reactions display for this message
        updateMessageReactions(msgIdLocal, j.reactions || []);
      } else {
        console.warn('react failed', j);
      }
    }catch(e){
      console.error('sendReaction failed', e);
    }
  }

  // compute initial position after next frame
  requestAnimationFrame(positionControls);
  // re-position on window resize/scroll so it stays aligned
  const onResizeOrScroll = () => positionControls();
  window.addEventListener('resize', onResizeOrScroll);
  window.addEventListener('scroll', onResizeOrScroll, true);

  // when row is removed later, also remove hotspot/wrap & pickers & listeners
  row._cleanupControls = () => {
    try{ hotspot.remove(); }catch(e){}
    try{ wrap.remove(); }catch(e){}
    try{ removeLocalQuick(); }catch(e){}
    try{ removeLocalFull(); }catch(e){}
    try{
      window.removeEventListener('resize', onResizeOrScroll);
      window.removeEventListener('scroll', onResizeOrScroll, true);
    }catch(e){}
  };

  // clicking the row should remove the toolbar/pickers (but not toggle the dot)
  row.addEventListener('click', (ev) => {
    removeMessageToolbar();
    hideWrap();
  });

  // append row to messages list
  messagesEl.appendChild(row);
  messagesEl.scrollTop = messagesEl.scrollHeight;
}

/* render reactions inline HTML */
function renderReactionsInline(reactions){
  if(!reactions || !reactions.length) return '';
  // build small pills
  return `<div class="reactions-row">${reactions.map(r => `<div class="reaction-pill" data-emoji="${escapeHtml(r.emoji)}">${escapeHtml(r.emoji)} <span>${escapeHtml(String(r.count||0))}</span></div>`).join('')}</div>`;
}

/* update the rendered reactions for a message */
function updateMessageReactions(msgId, reactions){
  const el = document.querySelector(`.msg-row[data-msgid="${msgId}"]`);
  if(!el) return;
  const bubble = el.querySelector('.bubble');
  if(!bubble) return;
  // remove any existing reactions-row
  const existing = bubble.querySelector('.reactions-row');
  if(existing) existing.remove();
  bubble.insertAdjacentHTML('beforeend', renderReactionsInline(reactions));
  // attach click handlers to reaction pills so local user can toggle by clicking pill
  const newPills = bubble.querySelectorAll('.reaction-pill');
  newPills.forEach(p => {
    // remove existing listener guard (avoid duplicates)
    if(p._attached) return;
    p._attached = true;
    p.addEventListener('click', async (ev) => {
      const emoji = p.dataset.emoji;
      await fetch(`/api/messages/${encodeURIComponent(msgId)}/react`, {
        method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ emoji })
      }).then(r=>r.json()).then(j => {
        if(j && j.success) updateMessageReactions(msgId, j.reactions || []);
      }).catch(e=>console.error(e));
    });
  });
}

