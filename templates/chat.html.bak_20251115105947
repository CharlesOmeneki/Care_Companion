    let promiseResolve, promiseReject;
    const p = new Promise((resolve, reject) => { promiseResolve = resolve; promiseReject = reject; });

    // timeout guard (optional) — not strictly necessary
    // setTimeout(()=> { if(!resolved){ resolved=true; cleanupHandlers(); backdrop.style.display='none'; promiseResolve(false); } }, 20*60*1000);

    return p;
