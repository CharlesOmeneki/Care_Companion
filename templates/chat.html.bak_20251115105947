 <!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Chat — Care Companion</title>

  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>
  <script src="https://cdn.socket.io/4.7.2/socket.io.min.js"></script>
    <style>
  :root{
    --blue-900:#0b3b66;
    --blue-700:#1066a3;
    --blue-500:#2b9bd6;
    --bg:#f6fbff;
    --muted:#6b7280;
    --glass: rgba(255,255,255,0.85);
    --radius:12px;
    --shadow: 0 6px 30px rgba(8,30,60,0.08);
    --danger: #ef4444;
    font-family: Inter, system-ui, -apple-system, "Segoe UI", Roboto, Arial;
  }
  html,body{height:100%;margin:0;background:linear-gradient(180deg,var(--bg),#ffffff);-webkit-font-smoothing:antialiased}
  .container{max-width:1200px;margin:26px auto;display:grid;grid-template-columns:84px 320px 1fr;gap:18px;min-height:74vh;padding:12px;}
  /* LEFT NAV (narrow) */
  .nav {
    background:var(--glass);border-radius:12px;padding:14px;box-shadow:var(--shadow);display:flex;flex-direction:column;gap:14px;align-items:center;
  }
  .nav .logo{width:44px;height:44px;border-radius:10px;background:linear-gradient(90deg,var(--blue-700),var(--blue-500));display:flex;align-items:center;justify-content:center;color:#fff;font-weight:800; cursor:pointer}
  .nav a{display:flex;flex-direction:column;align-items:center;gap:6px;text-decoration:none;color:var(--muted);font-size:13px;padding:8px;border-radius:10px;width:100%;justify-content:center}
  .nav a.active, .nav a:hover{background:rgba(11,66,160,0.06);color:var(--blue-900)}
  .nav i{font-size:18px}
  .nav .small{font-size:11px;color:var(--muted);}

  /* MIDDLE: conversations list */
  .conversations {
    background:white;border-radius:12px;padding:14px;box-shadow:var(--shadow);display:flex;flex-direction:column;
  }
  .conversations header{display:flex;align-items:center;justify-content:space-between;gap:8px;margin-bottom:10px}
  .conversations .title{font-weight:700}
  .conversations .search{display:flex;gap:8px}
  .conversations .search input{padding:8px 10px;border-radius:10px;border:1px solid rgba(10,25,47,0.04);width:100%}
  .conv-list{overflow:auto;border-radius:8px;padding-right:6px}
  .conv-item{display:flex;gap:10px;align-items:center;padding:10px;border-radius:10px;cursor:pointer}
  .conv-item:hover{background:rgba(11,66,160,0.03)}
  .conv-item .avatar{width:44px;height:44px;border-radius:10px;overflow:hidden;display:flex;align-items:center;justify-content:center}
  .conv-item .avatar img{width:44px;height:44px;object-fit:cover;display:block;margin:0 auto}
  .conv-item .meta{flex:1;min-width:0}
  .conv-item .name{font-weight:700;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
  .conv-item .snippet{font-size:13px;color:var(--muted);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
  .conv-item .time{font-size:12px;color:var(--muted);min-width:70px;text-align:right}
  .empty-convos{padding:38px;text-align:center;color:var(--muted)}

  /* Selected and unread styles */
  .conv-item.selected { background: rgba(11,66,160,0.06); outline: 1px solid rgba(11,66,160,0.04); }
  .conv-item.unread .name { font-weight: 800; }
  .conv-item .badge {
    background: var(--blue-500);
    color: white;
    padding: 6px 8px;
    border-radius: 999px;
    font-size: 12px;
    margin-left: 8px;
    min-width: 22px;
    text-align: center;
  }

  /* RIGHT: chat area (main) */
  .chat {
    background:white;border-radius:12px;padding:12px;box-shadow:var(--shadow);display:flex;flex-direction:column;
  }
  .chat .header{display:flex;align-items:center;justify-content:space-between;padding:6px 8px;border-bottom:1px solid rgba(10,25,47,0.04)}
  .chat .header .left{display:flex;gap:12px;align-items:center}
  .avatar-sm{width:46px;height:46px;border-radius:10px;overflow:hidden}
  .avatar-sm img{width:100%;height:100%;object-fit:cover}
  .chat .title{font-weight:700}
  .chat .sub{font-size:13px;color:var(--muted)}
  .messages{flex:1;overflow:auto;padding:18px 12px;display:flex;flex-direction:column;gap:10px;position:relative}
  .msg-row{display:flex;gap:10px;align-items:flex-end;max-width:75%;position:relative;transition: background .12s}
  .msg-row.me{margin-left:auto;flex-direction:row-reverse}
  .bubble{padding:10px 12px;border-radius:12px;background:linear-gradient(180deg,var(--blue-500),var(--blue-700));color:#fff}
  .bubble.me{background:linear-gradient(180deg,#e9f6ff,#d4f0ff);color:var(--blue-900);border:1px solid rgba(10,25,47,0.06)}
  .meta-time{font-size:12px;color:var(--muted);margin-top:6px}
  .composer{display:flex;gap:8px;align-items:center;padding:10px;border-top:1px solid rgba(10,25,47,0.04)}
  .composer textarea{flex:1;padding:12px;border-radius:10px;border:1px solid rgba(10,25,47,0.04);outline:none;resize:none;height:44px}
  .btn{padding:9px 12px;border-radius:10px;border:0;background:var(--blue-700);color:white;cursor:pointer}
  .btn.secondary{background:transparent;border:1px solid rgba(10,25,47,0.06);color:var(--blue-900)}

  /* Info dropdown (placed near header actions) and context menu */
  .info-menu, .ctx-menu {
    position: absolute;
    background: white;
    border-radius: 8px;
    box-shadow: 0 6px 24px rgba(8,30,60,0.12);
    padding: 8px;
    min-width: 200px;
    z-index: 1200;
    font-size: 14px;
  }
  .info-menu button, .ctx-menu button {
    display: flex;
    width:100%;
    text-align:left;
    padding:8px 10px;
    border: none;
    background: transparent;
    cursor: pointer;
    border-radius:6px;
    align-items:center;
    gap:8px;
  }
  .info-menu button:hover, .ctx-menu button:hover { background: rgba(11,66,160,0.05); }

  .info-menu button i, .ctx-menu button i { width:18px; display:inline-block; text-align:center; margin-right:10px; font-size:14px; }

  .danger { color: var(--danger); }
  .ctx-menu button.danger:hover, .info-menu button.danger:hover { background: rgba(239,68,68,0.06); }

  /* msg toolbar (when clicking the dot) - STACKED / VERTICAL layout */
  .msg-toolbar {
    position: absolute;
    display:flex;
    flex-direction: column;           /* make toolbar vertical */
    align-items: stretch;
    gap: 6px;
    background: white;
    border-radius: 8px;
    box-shadow: 0 6px 18px rgba(8,30,60,0.12);
    padding:6px;
    z-index:1400 !important; /* raised so toolbar sits above emoji pickers */
    font-size:13px;
    min-width: 160px;                /* reasonable minimum width for vertical stack */
  }
  /* toolbar buttons stacked and fill width */
  .msg-toolbar button {
    border:0;
    background:transparent;
    padding:8px 10px;
    border-radius:6px;
    cursor:pointer;
    display:flex;
    align-items:center;
    gap:10px;
    width:100%;                      /* full width so buttons are vertical and aligned */
    justify-content:flex-start;
    text-align:left;
  }
  .msg-toolbar button .fa { margin-right:6px; width:18px; text-align:center; }
  .msg-toolbar button.danger { color: var(--danger); }
  .msg-toolbar button:hover { background: rgba(11,66,160,0.03); }

  /* Invisible hotspot that sits beside each bubble.
     Hovering it reveals the visible three-dot and react buttons.
  */
  .msg-actions-hotspot {
    position: absolute;
    width:70px;   /* widened to cover both buttons side-by-side */
    height:36px;
    border-radius:50%;
    background: transparent;
    cursor: pointer;
    z-index: 800;
  }

  /* The visible controls wrapper we show when the hotspot is hovered (or the controls itself is hovered).
     Hidden by default.
  */
  .msg-actions-wrap {
    position: absolute;
    display:flex;
    gap:8px;
    align-items:center;
    background: transparent;
    z-index: 900;
    opacity: 0;
    visibility: hidden;
    transition: opacity .12s ease, transform .12s ease;
    pointer-events: none;
  }

  .msg-actions-wrap.visible { opacity:1; visibility:visible; transform:scale(1); pointer-events: auto; }

  .msg-actions-button, .react-button {
    width:34px;
    height:34px;
    border-radius:50%;
    display:flex;
    align-items:center;
    justify-content:center;
    background: rgba(0,0,0,0.03);
    border: none;
    font-size:14px;
    cursor:pointer;
  }

  /* icons color - use muted color to match three dots look */
  .msg-actions-button .fa, .react-button .fa { color: rgba(0,0,0,0.55); }

  /* emoji-picker popup */
  .emoji-picker {
    position: absolute;
    background: white;
    border-radius:8px;
    box-shadow: 0 8px 30px rgba(8,30,60,0.12);
    padding:8px;
    display:flex;
    gap:6px;
    flex-wrap:wrap;
    z-index:1300;
    min-width:160px;
    max-width:320px;
    user-select: none;
  }
  .emoji-picker.full { max-width:420px; padding:10px; grid-auto-rows:28px; display:grid; grid-template-columns: repeat(auto-fill, 36px); gap:6px; justify-content:start; }
  .emoji-picker button {
    border: none;
    background: transparent;
    cursor: pointer;
    padding:6px;
    font-size:18px;
    border-radius:6px;
    line-height:1;
  }
  .emoji-picker button:hover { background: rgba(11,66,160,0.04); }

  /* quick "more" button style */
  .emoji-more-btn { font-size:18px; padding:6px 10px; border-radius:6px; background: rgba(0,0,0,0.03); }

  /* reply snippet inside message bubble */
  .reply-snippet {
    background: rgba(255,255,255,0.12);
    color: rgba(255,255,255,0.9);
    padding:6px 8px;
    border-radius:8px;
    font-size:13px;
    margin-bottom:8px;
    max-width: 320px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .bubble.me .reply-snippet { background: rgba(10,25,47,0.04); color: var(--muted); }

  /* reactions row shown under each message */
  .reactions-row {
    display:flex;
    gap:8px;
    margin-top:8px;
    align-items:center;
    font-size:13px;
  }
  .reaction-pill {
    display:inline-flex;
    gap:6px;
    align-items:center;
    padding:6px 8px;
    background: rgba(0,0,0,0.04);
    border-radius:999px;
    cursor:pointer;
  }

  /* composer reply preview */
  .composer-reply {
    display:flex;
    align-items:center;
    gap:8px;
    padding:8px;
    border-top:1px solid rgba(0,0,0,0.04);
    border-bottom:1px solid rgba(0,0,0,0.04);
    background: rgba(250,250,250,0.6);
    font-size:13px;
  }
  .composer-reply .reply-text { color:var(--muted); overflow:hidden; text-overflow:ellipsis; white-space:nowrap }
  .composer-reply .reply-cancel { background:transparent; border:0; cursor:pointer; color:var(--muted) }

  /* make room for center controls so bubble doesn't overlap them */
  .msg-row { padding-left: 12px; padding-right: 12px; }
  .msg-row.me { padding-left: 48px; padding-right: 12px; }
  .msg-row:not(.me) { padding-right: 48px; padding-left: 12px; }

  /* Forward modal */
  .forward-modal-backdrop{
    position:fixed; inset:0; background: rgba(0,0,0,0.35); display:flex; align-items:center; justify-content:center; z-index:1600;
  }
  .forward-modal {
    width:92%;
    max-width:860px;
    background:#fff;
    border-radius:12px;
    box-shadow: 0 10px 40px rgba(0,0,0,0.18);
    overflow:hidden;
    display:flex;
    gap:0;
  }
  .forward-left { width: 360px; border-right:1px solid rgba(0,0,0,0.04); padding:14px; }
  .forward-right { flex:1; padding:14px; }
  .forward-title { font-weight:700; margin-bottom:8px; }
  .forward-quick { display:flex; gap:8px; flex-wrap:wrap; margin-bottom:12px; }
  .forward-quick button { display:flex; align-items:center; gap:8px; padding:8px 10px; border-radius:8px; border:1px solid rgba(0,0,0,0.06); background:transparent; cursor:pointer; transition: transform .06s ease, box-shadow .12s ease; }
  .forward-quick button:hover { transform: translateY(-3px); box-shadow: 0 10px 24px rgba(8,30,60,0.08); }
  .forward-quick .icon { width:22px; text-align:center; display:inline-flex; align-items:center; justify-content:center; }
  .forward-quick button .fa { font-size:16px; line-height:1; }

  /* App-specific quick button color styling */
  /* Icons and text inherit the color, border uses a soft tint */
  .forward-quick button { color: #333; }
  .forward-quick button .icon { color: inherit; }
  .forward-quick .app-email { border-color: rgba(0,0,0,0.12); color: #4b5563; }
  .forward-quick .app-whatsapp { border-color: #25D366; color: #0b8a4a; }
  .forward-quick .app-facebook { border-color: #1877F2; color: #1877F2; }
  .forward-quick .app-instagram { border-color: #E4405F; color: #E4405F; }
  .forward-quick .app-tiktok { border-color: #000000; color: #010101; }
  .forward-quick .app-x { border-color: #1DA1F2; color: #1DA1F2; }
  .forward-quick .app-telegram { border-color: #2AABEE; color: #2AABEE; }
  .forward-quick .app-copy { border-color: rgba(0,0,0,0.12); color: #374151; }

  /* subtle rounded icon background for stronger brand recognition (optional) */
  .forward-quick button .icon { width:22px; height:22px; border-radius:6px; display:inline-flex; align-items:center; justify-content:center; }

  .forward-list { max-height:420px; overflow:auto; margin-top:8px; }
  .forward-item { display:flex; gap:10px; align-items:center; padding:8px; border-radius:8px; cursor:pointer; }
  .forward-item:hover { background: rgba(11,66,160,0.03); }
  .forward-item .avatar { width:40px; height:40px; border-radius:8px; overflow:hidden; display:flex; align-items:center; justify-content:center; }
  .forward-item .meta { flex:1; min-width:0; }
  .forward-actions { display:flex; gap:8px; margin-top:10px; }
  .small-muted { font-size:13px; color:var(--muted); }

  @media (max-width:1000px){
    .container{grid-template-columns:64px 1fr; grid-auto-rows:auto}
    .conversations{display:none}
    .forward-left{ display:none; }
    .forward-modal { max-width: 95%; flex-direction:column; }
  }

  /* Block-banner styling (drop into existing <style>) */
.blocked-banner {
  display: none;
  padding: 10px 12px;
  border-radius: 10px;
  background: #fff1f0; /* light red */
  border: 1px solid rgba(239,68,68,0.12);
  color: #7f1d1d;
  font-size: 14px;
  margin: 8px 12px;
  align-items: center;
  justify-content: space-between;
  gap: 8px;
}
.blocked-banner .msg { flex: 1; }
.blocked-banner button { margin-left: 12px; padding:6px 10px; border-radius:8px; border:0; cursor:pointer; background:#ef4444; color:white; }
.blocked-banner .muted-btn { background: transparent; border: 1px solid rgba(0,0,0,0.06); color: #374151; }
 

  /* Slight tweaks for report modal to look modern */
#reportModalBackdrop .forward-modal { gap: 12px; }
#reportQuickReasons button { padding:8px 10px; border-radius:8px; border:1px solid rgba(0,0,0,0.06); background:transparent; cursor:pointer; }
#reportQuickReasons button:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(8,30,60,0.06); }
#reportSelectedReason { font-weight:600; }
 


/* composer icon sizing */
.composer .btn.secondary { width:44px; height:44px; display:inline-flex; justify-content:center; align-items:center; padding:0; }
.composer textarea { min-height:44px; max-height:160px; overflow:auto; }

/* Emoji Panel (vertical, tall, scrollable) */
.emoji-panel {
  position: absolute;
  bottom: 84px; /* above composer */
  right: 26px;
  width: 340px;
  max-height: 520px;
  background: white;
  border-radius: 12px;
  box-shadow: 0 12px 48px rgba(8,30,60,0.16);
  overflow-y: auto;
  padding: 10px;
  z-index: 2000;
  display: none;
}

/* emoji grid - many columns but overall vertical list feel */
.emoji-grid { display: grid; grid-template-columns: repeat(8, 1fr); gap:6px; align-items:center; justify-items:center; }
.emoji-grid button { border:0; background:transparent; font-size:20px; width:36px; height:36px; border-radius:6px; cursor:pointer; }
.emoji-grid button:hover { background: rgba(11,66,160,0.04); transform: translateY(-2px); }

/* emoji category header (optional) */
.emoji-category { font-weight:700; margin:8px 4px; color:var(--muted); }

/* narrow screens tweak */
@media (max-width:1000px){
  .emoji-panel { right: 8px; left: 8px; width: auto; bottom: 80px; max-height: 46vh; }
}

/* attachments inside message bubbles */
.message-attachments { margin-top:8px; display:flex; gap:8px; flex-wrap:wrap; align-items:flex-start; }
.message-attachments .att-img { max-width:320px; max-height:220px; border-radius:10px; object-fit:cover; border:1px solid rgba(0,0,0,0.06); display:block; }
.message-attachments .att-thumb { width:120px; height:80px; object-fit:cover; border-radius:8px; }
.message-attachments a.att-link { display:inline-block; text-decoration:none; color:inherit; }


/* ---------- Centered boxed image viewer (fits image into a box) ---------- */

.image-viewer-overlay {
  position: fixed;
  inset: 0;
  display: none;
  align-items: center;
  justify-content: center;
  z-index: 3000;
  background: rgba(0,0,0,0.45);
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}
.image-viewer-overlay.visible { display: flex; }

/* The box that contains the image (centered, not fullscreen) */
.image-viewer-inner {
  width: min(900px, 90vw);    /* desktop max width 900px, responsive */
  height: min(600px, 70vh);   /* desktop max height 600px, responsive */
  max-width: 90vw;
  max-height: 70vh;
  background: #0b1220;        /* subtle dark frame */
  border-radius: 10px;
  padding: 12px;
  box-sizing: border-box;
  display: flex;
  align-items: center;        /* center vertically */
  justify-content: center;    /* center horizontally */
  position: relative;
  box-shadow: 0 12px 48px rgba(2,6,23,0.48);
}

/* framing area inside the box (keeps caption/close layered) */
.image-viewer-frame {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
}

/* Image: always fully visible inside the box */
.image-viewer-frame img.viewer-img {
  display: block;
  max-width: 100%;
  max-height: 100%;
  width: auto;
  height: auto;
  object-fit: contain;           /* show entire image, preserve ratio */
  object-position: center center;
  border-radius: 6px;
  box-shadow: 0 8px 28px rgba(0,0,0,0.45);
  background: rgba(255,255,255,0.02);
}

/* Close button top-right of the box */
.image-viewer-close {
  position: absolute;
  right: 10px;
  top: 10px;
  z-index: 12;
  border: 0;
  padding: 8px 10px;
  border-radius: 8px;
  cursor: pointer;
  color: #fff;
  background: rgba(0,0,0,0.35);
  font-weight: 700;
}

/* Caption bottom-left inside the box */
.image-viewer-caption {
  position: absolute;
  left: 12px;
  bottom: 10px;
  z-index: 11;
  color: #fff;
  font-size: 13px;
  max-width: calc(100% - 48px);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* Mobile tweaks: slightly smaller box */
@media (max-width:600px){
  .image-viewer-inner { width: min(92vw, 92vw); height: min(56vh, 56vh); padding: 8px; }
  .image-viewer-frame img.viewer-img { max-width: 100%; max-height: 100%; }
  .image-viewer-close { right: 8px; top: 8px; padding:6px 8px; }
  .image-viewer-caption { left: 8px; bottom: 8px; font-size:12px; }
}





</style>
 
  
</head>
<body>
  <div class="container" role="application">

    <!-- LEFT NAV (permanent) -->
    <nav class="nav" aria-label="main navigation">
      <div class="logo" id="ccLogo">CC</div>

      <a href="{{ url_for('home') }}" title="Home"><i class="fa fa-house"></i><div class="small">Home</div></a>
      <a href="{{ url_for('find_caregiver') }}" title="Find caregivers"><i class="fa fa-users"></i><div class="small">Find</div></a>
      <a class="active" href="{{ url_for('chat_page', other_id=0) | replace('/0','') }}" title="Messages"><i class="fa fa-envelope"></i><div class="small">Messages</div></a>
      <a href="{{ url_for('profile_setup') }}" title="Profile"><i class="fa fa-user"></i><div class="small">Profile</div></a>

      <div style="flex:1"></div>
      <div style="font-size:12px;color:var(--muted);text-align:center">Care Companion</div>
    </nav>

    <!-- MIDDLE: Conversations list (only actual conversations are shown) -->
    <section class="conversations" aria-label="conversations">
      <header>
        <div>
          <div class="title">Messages</div>
          <div class="small" style="color:var(--muted)">Direct messages</div>
        </div>
        <div class="search" style="width:160px">
          <input id="searchInput" placeholder="Search" />
        </div>
      </header>

      <div class="conv-list" id="convList" aria-live="polite" role="list">
        <!-- conversation items injected here -->
      </div>

      <div id="noConvos" class="empty-convos" style="display:none">
        <div style="font-weight:700;font-size:15px">No conversations yet</div>
        <div style="margin-top:8px;color:var(--muted)">Start a chat from the Connections page or search for a user.</div>
      </div>
    </section>

    <!-- RIGHT: Chat / Profile / Content -->
    <main class="chat" aria-label="chat window">
      <div class="header">
        <div class="left">
          <div class="avatar-sm"><img id="otherAvatar" src="{{ url_for('static', filename='default-avatar.png') }}" alt=""></div>
          <div>
            <div class="title" id="otherName">No conversation selected</div>
            <div class="sub" id="otherSub">Select a conversation to start</div>
          </div>
        </div>
        <div>
          <!-- Info button: opens the Report / Block / Clear UI (common place on many sites) -->
