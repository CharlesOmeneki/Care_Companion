    if(first) first.classList.add('selected');
    previewReason.textContent = QUICK_REASONS[0];

    detailsEl.value = '';
    previewDetails.textContent = '(no additional details)';
    targetTitle.textContent = targetName ? `Reporting ${targetName}` : `Reporting user (${targetUserId})`;

    backdrop.style.display = 'flex';
    submitBtn.disabled = false;
    submitBtn.textContent = 'Send report';

    // wire once handlers
    let resolved = false;
    let cleanupHandlers = () => {
      try { closeBtn.removeEventListener('click', onCancel); } catch(e){}
      try { cancelBtn.removeEventListener('click', onCancel); } catch(e){}
      try { submitBtn.removeEventListener('click', onSubmit); } catch(e){}
      detailsEl.removeEventListener('input', onDetailsInput);
    };

    function onDetailsInput(){ previewDetails.textContent = detailsEl.value.trim() || '(no additional details)'; }

    function onCancel(){
      if(resolved) return;
      resolved = true;
      cleanupHandlers();
      backdrop.style.display = 'none';
      // resolve with false to indicate user cancelled
      promiseResolve(false);
    }

    async function onSubmit(){
      if(resolved) return;
      const selected = quickContainer.querySelector('button.selected');
      const reason = selected ? selected.textContent : QUICK_REASONS[0];
      const details = detailsEl.value.trim();

      // validate at least a reason (we always have one)
      submitBtn.disabled = true;
      submitBtn.textContent = 'Sending...';

      try {
        const res = await fetch(`/api/report/${encodeURIComponent(targetUserId)}`, {
          method: 'POST',
          headers: {'Content-Type':'application/json'},
          body: JSON.stringify({ reason, details })
        });
        const j = await res.json().catch(()=>({}));

        if(res.ok && j && j.success){
          // success: close modal and resolve true
          resolved = true;
          cleanupHandlers();
          backdrop.style.display = 'none';
          promiseResolve(true);
          return;
