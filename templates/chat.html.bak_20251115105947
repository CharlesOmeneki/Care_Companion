(function installMessagesAttachmentHandler(){
  const messagesContainer = document.getElementById('messages');
  if(!messagesContainer) return;

  // idempotent guard
  if(messagesContainer._attachmentHandlerInstalled) return;
  messagesContainer._attachmentHandlerInstalled = true;

  messagesContainer.addEventListener('click', function(e){
    try {
      // left-click only
      if(typeof e.button !== 'undefined' && e.button !== 0) return;

      // If viewer already open, ignore so clicks do not re-open
      if(window.__imageViewerVisible) return;

      // Respect modifier keys (open in new tab/window)
      if(e.ctrlKey || e.metaKey || e.shiftKey) return;

      // If click is inside overlay (shouldn't happen here), ignore
      const ov = document.getElementById('imageViewerOverlay');
      if(ov && ov.contains(e.target)) return;

      // find nearest .att-link ancestor and ensure it contains an <img>
      const a = e.target && e.target.closest ? e.target.closest('.att-link') : null;
      if(!a || !messagesContainer.contains(a)) return;
      const containedImg = a.querySelector && a.querySelector('img');
      if(!containedImg) return;

      // Prevent normal navigation and stop propagation so other older handlers don't run
      e.preventDefault();
      e.stopPropagation();

      // Derive url and caption and open boxed viewer
      const url = a.href || containedImg.src || containedImg.getAttribute('src') || containedImg.dataset.src;
      const caption = containedImg.getAttribute('alt') || containedImg.title || '';
      if(!url) return;
      openImageViewer(url, caption);
    } catch(err){
      console.error('messages attachment click handler error', err);
    }
  }, false); // bubble-phase is fine here (we preventPropagation above)
})();

/* ---------------- Safety note ----------------
1) Remove any other document/global handlers that also open attachments (search for
   "document.addEventListener('click'" or "openImageViewer(" or ".att-link") in your files).
   Keeping duplicates can reintroduce conflicts.

2) If you previously monkey-patched window.open/location.assign/replace, remove those patches.
   This script uses a safer approach (capture blocker + guarded delegated handler).
*/
