/* 2) Prefer server-hosted socket.io client (ensures version parity) + CDN fallback */
(function(){
  // Try to prefer the server-provided client first: /socket.io/socket.io.js
  function injectScript(src, onload, onerror){
    const s = document.createElement('script');
    s.src = src;
    s.async = false;
    s.onload = onload || function(){};
    s.onerror = onerror || function(){};
    document.head.appendChild(s);
  }
  // If `io` already present, do nothing.
  if(typeof io === 'undefined'){
    // Try server-served client first
    injectScript('/socket.io/socket.io.js', function(){ console.debug('socket.io client loaded from server /socket.io/socket.io.js'); }, function(){
