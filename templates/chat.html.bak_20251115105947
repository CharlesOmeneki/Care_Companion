let blockedCache = null;              // cached list of { blocked_id, created_at } that current user blocked
const blockedByOthers = new Set();    // set of user ids who have blocked current user (populated by socket events)

async function loadBlockedCache(force = false){
  if(blockedCache && !force) return blockedCache;
  try{
    const res = await fetch('/api/blocked');
    if(!res.ok) { blockedCache = []; return blockedCache; }
    blockedCache = await res.json();
    return blockedCache;
  }catch(e){
    console.error('loadBlockedCache failed', e);
    blockedCache = [];
    return blockedCache;
  }
}

function isBlockedByMe(otherId){
  if(!otherId) return false;
  if(!blockedCache) return false;
  return blockedCache.some(b => Number(b.blocked_id) === Number(otherId));
}

function isBlockedByOther(otherId){
  if(!otherId) return false;
  return blockedByOthers.has(Number(otherId));
}

async function blockUserToggle(otherId, shouldBlock = true){
  if(!otherId) throw new Error('missing otherId');
  try{
    const res = await fetch(`/api/block/${encodeURIComponent(otherId)}`, {
      method: 'POST',
      headers: {'Content-Type':'application/json'},
      body: JSON.stringify({ block: !!shouldBlock })
    });
    const j = await res.json();
    if(res.ok && j.success){
      await loadBlockedCache(true);
      if(!shouldBlock) blockedByOthers.delete(Number(otherId));
      applyBlockedUIForActive();
      loadData();
      return true;
    } else {
      console.warn('blockUserToggle failed', j);
      alert('Failed to update block state: ' + (j.error || 'unknown'));
      return false;
    }
  }catch(e){
    console.error('blockUserToggle error', e);
    alert('Failed to update block state');
    return false;
  }
}

function ensureBlockBanner(){
