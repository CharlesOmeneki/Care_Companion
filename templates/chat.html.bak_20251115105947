    const ov = document.getElementById('imageViewerOverlay');
    if (ov && ov.contains(ev.target)) {
      return; // allow overlay handlers; do not continue with legacy code
    }
    // Otherwise block this click entirely to prevent reopen loop
    try { ev.stopImmediatePropagation(); } catch (e) {}
    try { ev.preventDefault(); } catch (e) {}
    return;
  }
} catch (err) {
  console.debug('viewer-guard early-return failed', err);
  // fall through to legacy behavior if something unexpectedly errors
}


